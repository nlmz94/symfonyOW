{% extends 'base.html.twig' %}

{% block title %}404 - Page Not Found{% endblock %}

{% block meta_description %}The page you're looking for doesn't exist or has been moved.{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <div class="mb-4">
                    <svg width="100" height="100" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M50 0C22.3858 0 0 22.3858 0 50C0 77.6142 22.3858 100 50 100C77.6142 100 100 77.6142 100 50C100 22.3858 77.6142 0 50 0ZM50 8C25.4844 8 8 25.4844 8 50C8 74.5156 25.4844 92 50 92C74.5156 92 92 74.5156 92 50C92 25.4844 74.5156 8 50 8Z" fill="#6c757d"/>
                        <path d="M40 60H60V40H40V60ZM38 62H62V38H38V62Z" fill="#6c757d"/>
                        <path d="M40 40L60 60M60 40L40 60" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                
                <h1 class="display-1 fw-bold text-danger mb-4">404</h1>
                <h2 class="h3 mb-3">Page Not Found</h2>
                <p class="lead text-muted mb-4">
                    The page you're looking for doesn't exist or has been moved.
                </p>
                
                <div class="alert alert-info mb-4">
                    <strong>Don't worry!</strong> You can explore our anime collection or search for what you're looking for.
                </div>
                
                <div class="d-flex justify-content-center gap-3 mb-4">
                    <a href="{{ path('app_home') }}" class="btn btn-primary">
                        Go to Homepage
                    </a>
                    <a href="{{ path('app_anime') }}" class="btn btn-outline-primary">
                        Browse Anime
                    </a>
                </div>
                
                <div class="card mt-4">
                    <div class="card-body">
                        <h5 class="card-title">Search our collection</h5>
                        <form action="{{ path('app_anime') }}" method="get" class="d-flex">
                            <input type="text" name="searchTerm" class="form-control me-2" placeholder="Search anime..." required>
                            <button type="submit" class="btn btn-success">Search</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}