{% extends 'base.html.twig' %}
{% import '_icons.html.twig' as icons %}
{% block title %}Create account{% endblock %}

{% block meta_description %}Create your free OnlyWeebs account to track favorites, rate anime series, build your watchlist, and discover personalized recommendations from our collection of 22,000+ titles.{% endblock %}

{% block body %}
    <div class="d-flex justify-content-center align-items-center min-vh-100 bg-light">
        <div class="card shadow-sm" style="width: 100%; max-width: 400px;">
            <div class="card-body p-4">
                <h1 class="h4 mb-4 text-center">Create account</h1>

                {{ form_start(registrationForm, {attr: {class: 'needs-validation', novalidate: 'novalidate'}}) }}

                <div class="mb-3">
                    {{ form_label(registrationForm.email, null, {label_attr: {class: 'form-label'}}) }}
                    {{ icons.icon('envelope-fill', 'me-1') }} {{ form_widget(registrationForm.email, {attr: {class: 'form-control', autocomplete: 'email'}}) }}
                    <div class="invalid-feedback">
                        {{ form_errors(registrationForm.email) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(registrationForm.password.first, null, {label_attr: {class: 'form-label'}}) }}
                    {{ icons.icon('lock-fill', 'me-1') }} {{ form_widget(registrationForm.password.first, {attr: {class: 'form-control', autocomplete: 'new-password'}}) }}
                    <div class="invalid-feedback">
                        {{ form_errors(registrationForm.password) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(registrationForm.password.second, null, {label_attr: {class: 'form-label'}}) }}
                    {{ icons.icon('lock-fill', 'me-1') }} {{ form_widget(registrationForm.password.second, {attr: {class: 'form-control', autocomplete: 'new-password'}}) }}
                </div>

                {{ form_widget(registrationForm.submit, {attr: {class: 'btn btn-success w-100 mt-3'}}) }}
                {{ form_end(registrationForm) }}
            </div>
        </div>
    </div>
{% endblock %}
